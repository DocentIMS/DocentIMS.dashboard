<html xmlns="http://www.w3.org/1999/xhtml"
      xmlns:metal="http://xml.zope.org/namespaces/metal"
      xmlns:tal="http://xml.zope.org/namespaces/tal"
      xmlns:i18n="http://xml.zope.org/namespaces/i18n"
      i18n:domain="DocentIMS.dashboard"
      metal:use-macro="context/main_template/macros/master">
<body>

  <metal:custom_title fill-slot="content-title">
    <h1 tal:replace="structure context/@@title" />

    <!-- @@title view template: -->
    <!--
    <h1 tal:define="title context/Title" tal:condition="title" tal:content="title">
      Title or id
    </h1>
    -->

  </metal:custom_title>

  <metal:custom_description fill-slot="content-description"> 
  </metal:custom_description>

  <metal:content-core fill-slot="content-core">
  <metal:block define-macro="content-core">

  <div class="testEmailBox">
    <form method="post" action="">
      <label for="test_email"><strong>Send a test email to:</strong></label>
      <input type="email" id="test_email" name="test_email" placeholder="you@example.com" required="required" size="32" />
      <button type="submit" name="send_test" value="1" class="btn btn-primary plone-btn plone-btn-primary">Send test</button>
    </form>
    <p class="portalMessage info" tal:condition="view/status" tal:content="view/status" />
    <p class="discreet">The preview below is filled with your own account / this context as sample data, so you can see exactly how a recipient's email will look. The test email sends that same content.</p>
  </div>

  <hr/>

  <div tal:replace="structure view/get_email_content" />

  </metal:block>
  </metal:content-core>
</body>
</html>
