<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" i18n:domain="DocentIMS.dashboard" metal:use-macro="context/main_template/macros/master">
  <body>
    <metal:content-core fill-slot="content">
      <metal:block define-macro="content">
        <div class="row">
          <h3 style="text-align:center; font-family: 'Times', 'Times New Roman', 'Brush Script MT', 'Brush Script', 'Courier New', 'Courier'">Docent Dashboard</h3>
        </div>
 
  <meta charset="utf-8" />

  <!-- FullCalendar CSS -->
  <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">

  <!-- FullCalendar JS -->
  <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

  <style>
    #filters {
      margin-bottom: 1em;
    }

    #filters label {
      margin-right: 1em;
      font-weight: bold;
    }

    #calendar {
      max-width: 900px;
      margin: 0 auto;
    }
  </style>
 

<h2>Meetings Calendar</h2>

<!-- Filters -->
<div id="filters">
  <label><input type="checkbox" value="board" checked> Board</label>
  <label><input type="checkbox" value="staff" checked> Staff</label>
  <label><input type="checkbox" value="Project Team Meeting" checked> Project Team Meeting</label>
   <label><input type="checkbox" value="" checked> Meeting</label>
 
 
</div>

<!-- Calendar -->
<div id="calendar"></div>

<script>
document.addEventListener('pat-inject-success', function (e) {


  // e.target = element that was injected into (#appWrapper)
  const container = e.target;

 

  // 🎯 Dummy meetings (simulate REST API)
  const meetings = Array.from(document.querySelectorAll("#meetings .meeting"))
          .map(el => ({
            title: el.dataset.title,
            start: el.dataset.start,
            end: el.dataset.end,
            category: el.dataset.category,
            location: el.dataset.location,
            url: el.dataset.url
          })); 
   
  console.log(meetings);

  
  // 🎨 Category colors
  const categoryColors = {
    board: '#e74c3c',
    staff: '#3498db',
    public: '#2ecc71'
  };

  // Active filters
  let activeCategories = ['board', 'staff', 'public'];

  // Convert to FullCalendar format
  function getFilteredEvents() {
    return meetings
      .filter(m => activeCategories.includes(m.category))
      .map(m => ({
        title: m.title,
        start: m.start,
        end: m.end,
        backgroundColor: categoryColors[m.category],
        borderColor: categoryColors[m.category],
        extendedProps: {
          category: m.category
        }
      }));
  }

  // 📅 Init calendar
  const calendar = new FullCalendar.Calendar(
    document.getElementById('calendar'),
    {
      initialView: 'dayGridMonth',
      height: 'auto',

      events: function(fetchInfo, successCallback) {
        successCallback(getFilteredEvents());
      }
    }
  );

  calendar.render();

  // 🎛️ Filter handling
  document.querySelectorAll('#filters input').forEach(cb => {
    cb.addEventListener('change', () => {
      activeCategories = Array.from(
        document.querySelectorAll('#filters input:checked')
      ).map(el => el.value);

      calendar.refetchEvents();
    });
  });

});
</script> 









        <main class="appWrapper">

          <!-- sidebar -->
          <!-- mobile header -->
          <!-- mobileSidebar -->
          <!-- main app content -->

          <div class="wrapper" tal:define="current view/get_fullname|None;
          colors view/get_colors|None">
            <!-- <p>IP Address: ${view/get_served_domain_ip} ( ${view/get_server_ip} )</p> -->
            <p></p>

            <div class="pageHeading flexing">
              <!-- <h2>
                <tal:condition tal:condition="current|None">${view/get_fullname}'s </tal:condition>Projects </h2> -->
              <!-- <div class="rightlogo">
                <img src="++plone++DocentIMS.ActionItems/docentlogo.jpg" width="200" alt="logo" title="Logo" />
              </div> -->

            </div>
            <div class="wrapper loader">
              <p>
                <span class=" projectselect" tal:condition="current|None">Please select project…</span> &nbsp;</p>

            </div>

            <div class="projectButton" tal:condition="current|None">
              <div class="card">
                <div class="card-body" tal:define="button view/get_buttons|None">
                  <ul class="nav nav-tabs" id="myTab" role="tablist">
                    <div tal:condition="not: button">You dont have any projects, yet.<br/>
                      NOTE: (New) Projects might take 15 minutes to show up.
                    </div>
                    <tal:repeat tal:repeat="button python:view.get_buttons()">
                      <li class="nav-item" role="presentation" tal:define="active python: 'active' if repeat.button.index == 0 else 'click'">
                        <a style="background-color: ${python: button['project_color']}" class="button btn pat-inject ${active}" href="${context/absolute_url}/app-inject-view?siteurl=${python: button['url']}" data-pat-inject="source: #appWrapper; target: #appWrapper">
 												 ${python: button['name']} 
                          <span class="newproject" tal:condition="python: button['last_login_time']">
                            <br/>
                                  New Project</span>
                        </a>
                    
                        <p class="center" tal:condition="view/check_editperm">
                          <a href="${python: button['edit_url']}/edit">✎</a>
                        </p>
                      </li>
                    </tal:repeat>
                    <!-- <li>Updated: ${view/get_current_time} <br/>
                    <a href="${context/absolute_url}" style="background-color: #123456" class="button btn standalone"> ⟳ Refresh</a>
                  </li> -->


                  </ul>
                </div>
              </div>
            </div>            <!-- buttons-->

            <div>
              <p class="text-right">Updated: ${view/get_current_time} <a href="${context/absolute_url}?refresh=1">
                <img src="++plone++DocentIMS.dashboard/refresh-icon.png" width="24" height="24"> Refresh</a>
              </p>
            </div>


            <div id="appWrapper" class="projectPreview">
              <a tal:condition="not: current|None" 
                class="loginbutton plone-btn plone-btn-large plone-btn-primary pat-plone-modal" 
                data-pat-plone-modal="width: 400" title="Log in" href="login" icon="plone-login">Please Log in first
              </a>

              <div>
              <p>&nbsp;</p>
                <!-- <p><a href="${context/absolute_url}/@@login-help" tal:condition="not: current|None"  >Set Password -->             
                <!-- </a></p> -->
              </div> 

            </div>




          </div>          <!-- wrapper-->

          <style tal:define="colors view/get_colors">
            .text-right {text-align: right; padding-top: 1rem;}
            .newproject {color: yellow}
            .appWrapper .sideBar,
            #main-container a.button,
            .projectButton .p1 {
              background-color: ${project_color|None};
            }

             #main-container a.button,
             #main-container a.button  click  { opacity: 0.35}
             #main-container a.button.active { opacity: 1}

            .projectPreview .topInfo h3,
            .projectPreview .card .card-body .top h3 {
              color: ${color|None};
            }

                                                <!-- .color-0 { background-color: ${python: colors[0]} }
            .color-1 { background-color: ${python: colors[1]} }
            .color-2 { background-color: ${python: colors[2]} }
            .color-3 { background-color: ${python: colors[3]} }
            .color-4 { background-color: ${python: colors[4]} }
            .color-5 { background-color: ${python: colors[0]} } -->

            <!-- .color-0 , .color-1 , .color-2 , .color-3, .color-4, .color-4  { background-color:${python: button['project_color']} } -->




            <!-- body:not(.userrole-manager) #edit-zone {display: block !important; width: 240px}  -->
        .pat-toolbar, #edit-bar, #edit-zone {
            border-radius: 0 20px 20px 0;
            xbackground: #976100;
            xbackground: white;
            
        }
        .small {font-size: 1rem !important; font-weight: normal; color: #DDD}    
          

        a#personaltools-menulink { background-color: black; }

        #edit-zone .personaltools-wrapper  {border-top: 0 none;}

        body:not(.userrole-manager)  div.toolbar-header, 
        body:not(.userrole-manager) ul.plone-toolbar-main { display: none}

        body { background: #FAF9F6}


            
          </style>


 
 





        </main>

      </metal:block>
    </metal:content-core>
  </body>
</html>
