<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" i18n:domain="DocentIMS.dashboard" metal:use-macro="context/main_template/macros/master">
  <body>
    <metal:content-core fill-slot="content">
      <metal:block define-macro="content">
        <!-- FullCalendar CSS -->
        <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.css" rel="stylesheet">

          <!-- FullCalendar JS -->
          <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.11/index.global.min.js"></script>

          <div class="row">
            <h3 class="dashboardHeading">Docent Dashboard</h3>
          </div>

          <main class="appWrapper">

                <div class="wrapper" tal:define="current view/get_fullname|None">
                  <div class="wrapper loader">
                    <p>
                      <span class=" projectselect" tal:condition="current|None">Please select project…</span> &nbsp;</p>
                  </div>

                  <!-- one card holds the project pills AND the injected panel -->
                  <div class="mainCard">
                    <div class="projectButton cardtop" tal:condition="current|None" tal:define="button view/get_buttons|None">
                      <ul class="nav nav-tabs" id="myTab" role="tablist">
                        <div tal:condition="not: button">You dont have any projects, yet.<br/>
                           NOTE: (New) Projects might take 15 minutes to show up.
                        </div>
                        <tal:repeat tal:repeat="button python:view.get_buttons()">
                          <li class="nav-item" role="presentation" tal:define="active python: 'active' if repeat.button.index == 0 else 'click'">
                            <a style="background-color: ${python: button['project_color']}" class="button btn pat-inject ${active}" href="${context/absolute_url}/app-inject-view?siteurl=${python: button['url']}" data-pat-inject="source: #appWrapper; target: #appWrapper${python: '; trigger: autoload' if active == 'active' else ''}">
 												 ${python: button['name']}
                              <span class="newproject" tal:condition="python: button['last_login_time']">
                                <br/>
                                New Project</span>
                            </a>

                            <p class="center" tal:condition="view/check_editperm">
                              <a href="${python: button['edit_url']}/edit">✎</a>
                            </p>
                          </li>
                        </tal:repeat>
                      </ul>
                    </div>   <!-- pills -->

                    <div id="appWrapper" class="projectPreview">
                      <a tal:condition="not: current|None"
                          class="loginbutton plone-btn plone-btn-large plone-btn-primary pat-plone-modal"
                          data-pat-plone-modal="width: 400" title="Log in" href="${context/absolute_url}/login"
                          icon="plone-login">Please Log in first
                      </a>
                    </div>
                  </div>   <!-- mainCard -->
                </div>
              </main>

              <div class="calWrap">

          <button id="toggler" tal:condition="view/get_fullname|None"
          class="btn btn-standalone btn-primary toggler">Calendar: Meetings for Project</button>
          <div id="calendardiv" class="opacity0">

            <!-- Filters -->
            <div id="filters" class="flex" style="display: flex; background: whitesmoke">
              <label tal:repeat="meeting_type view/get_meeting_types|None">
                <input type="checkbox" value="meeting_type" checked/> ${meeting_type}
              </label>
            </div>

            <!-- Calendar -->
            <div id="calendar" class="calendar"></div>
          </div>
              </div>

          <!-- Calendar behaviour (guarded; no-ops when the calendar is absent) -->
          <script src="++plone++DocentIMS.dashboard/calendar.js"></script>

            </metal:block>
          </metal:content-core>
        </body>
      </html>
