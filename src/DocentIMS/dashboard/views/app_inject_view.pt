<html xmlns="http://www.w3.org/1999/xhtml"
  xmlns:metal="http://xml.zope.org/namespaces/metal"
  xmlns:tal="http://xml.zope.org/namespaces/tal"
  xmlns:i18n="http://xml.zope.org/namespaces/i18n" i18n:domain="DocentIMS.dashboard" metal:use-macro="context/main_template/macros/master">
  <body>
    <metal:content-core fill-slot="content">
      <metal:block define-macro="content">

        <div id="appWrapper">

          <div id="meetings">
            <tal:loop tal:repeat="item view/get_calendar_list|None">
              <div class="meeting" tal:attributes="
                data-title item/title;
                data-start item/start;
                data-end item/end;
                data-category item/category;
                data-location item/location;
                data-url item/url;">
              </div>
            </tal:loop>
          </div>

          <div tal:define="dashboard_items view/dashboard_info;
                           dashboard_list dashboard_items/dashboard-list|nothing">

            <!-- Graceful fallback: the project site could not be reached or
                 returned an unexpected response. -->
            <p class="projectLoadError" tal:condition="not: dashboard_list">
              This project could not be loaded right now. Please try
              <a href="${context/absolute_url}?refresh=1">refreshing</a>.
            </p>

            <main class="appWrapper" tal:condition="dashboard_list"
                  tal:define="url dashboard_list/site_url">

              <div class="wrapper">
                <div class="pageHeading">
                  <div class="projectPreview">
                    <div class="tab-content" id="myTabContent">
                      <div class="card mainbox">

                        <div class="card-body">
                          <div class="userInfo">
                            <h3>
                              <details class="userMenu">
                                <summary class="userMenuToggle" title="Account menu" tal:define="icon view/get_user_icon|nothing">
                                  <img tal:condition="icon" src="${icon}" alt="User icon" />
                                  <svg tal:condition="not: icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" width="48" height="48">
                                    <path fill-rule="evenodd" d="M7.5 6a4.5 4.5 0 1 1 9 0 4.5 4.5 0 0 1-9 0ZM3.751 20.105a8.25 8.25 0 0 1 16.498 0 .75.75 0 0 1-.437.695A18.683 18.683 0 0 1 12 22.5c-2.786 0-5.433-.608-7.812-1.7a.75.75 0 0 1-.437-.695Z" clip-rule="evenodd" />
                                  </svg>
                                </summary>
                                <div class="userMenuDropdown">
                                  <a href="/logout">Log Out</a>
                                  <a href="/@@personal-information">Set Profile</a>
                                  <a href="/@@set-user-icon">Set Icon</a>
                                </div>
                              </details>
                              <span>${dashboard_list/user} – ${dashboard_list/your_team_role}
                              </span>
                            </h3>
                          </div>

                          <div class="topItemBox">
                            <div class="top">
                              <h3>
                                <a href="${url}/action-items/action-items-collection" target="_blank" rel="noopener noreferrer">Your Tasks</a>
                              </h3>
                            </div>
                            <div class="itemWrapper">
                              <div class="row">
                                <div tal:repeat="urgency dashboard_list/urgency_list" class="col-xl-3 col-lg-6 col-md-6 col-12">
                                  <div tal:define="urgclass urgency/name; count urgency/count" class="color-${python: repeat.urgency.index} singleItem ${python: urgclass.split(' ', 1)[0]} count-${count}">
                                    <h4 tal:define="urgname urgency/name" class="black">${python: urgname.replace("More than", ">")}</h4>
                                    <h2>${count}</h2>
                                    <div class="detailsBtn">
                                      <a href="${url}/action-items/action-items-collection?collectionfilter=1&urgency=${urgency/name}" target="_blank" tal:condition="python: count != 0" class="xwhite-text">
                                             More Details
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                                        </svg>
                                      </a>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div class="bottomItemBox">
                            <div class="top">
                              <h3>
                                <a href="${url}/meetings" target="_blank" rel="noopener noreferrer">Meetings</a>
                              </h3>
                            </div>
                            <div class="itemWrapper">
                              <div class="row">
                                <div tal:repeat="meeting dashboard_list/meeting_list" class="col-xl-3 col-lg-6 col-md-6 col-12">
                                  <div tal:define="count meeting/count" class="singleItem meeting count-${count}">
                                    <h4>${meeting/name}</h4>
                                    <h2>${count}</h2>
                                    <div class="detailsBtn">
                                      <a href="${url}/meetings" target="_blank" tal:condition="python: count != 0" class="xwhite-text">
                                          More Details
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                                        </svg>
                                      </a>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div class="bottomItemBox">
                            <div class="top">
                              <h3>
                                <a href="${url}/notifications/notifications-collection" target="_blank" rel="noopener noreferrer">
                                    Alerts
                                </a>
                              </h3>
                            </div>
                            <div class="itemWrapper">
                              <div class="row">
                                <div tal:repeat="notification dashboard_list/notification_list" class="col-xl-3 col-lg-6 col-md-6 col-12">
                                  <div tal:define="name notification/name; count notification/count" class="singleItem notification note-${name} count-${count}">
                                    <h4 class="title-${name}">${name}</h4>
                                    <h2>${count}</h2>
                                    <div class="detailsBtn">
                                      <a href="${url}/notifications/notifications-collection?collectionfilter=1&notification_type=${name}&sort_on=created&sort_order=ascending" target="_blank" tal:condition="python: count != 0" class="xwhite-text">
                                          More Details
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-6">
                                          <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25 21 12m0 0-3.75 3.75M21 12H3" />
                                        </svg>
                                      </a>
                                    </div>
                                  </div>
                                </div>
                              </div>
                            </div>
                          </div>

                          <div class="cardfoot">
                            <span><b>Project Info Updated:</b> ${python: view.strip_weekday(dashboard_list.get('last_updated', ''))}</span>
                            <span class="sep">·</span>
                            <span><b>Dashboard updated:</b> ${view/get_current_time}</span>
                            <a class="refreshLink" href="${context/absolute_url}?refresh=1">↻ Refresh</a>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Per-project dynamic styling (depends on the project colour /
                   short name).  Static rules live in dashboard.css. -->
              <style>
                div.card-header { background: ${dashboard_list/project_color|None}; color: white; }
                div.card-header a { color: white !important; }
                .info_portlet { display: none; }
                .info_portlet.${python: dashboard_list['short_name'].replace(" ", ".")} { display: block; }
              </style>

            </main>
          </div>

        </div>
      </metal:block>
    </metal:content-core>
  </body>
</html>
