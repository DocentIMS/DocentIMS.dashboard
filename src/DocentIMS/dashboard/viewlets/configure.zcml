<configure
    xmlns="http://namespaces.zope.org/zope"
    xmlns:browser="http://namespaces.zope.org/browser"
    xmlns:plone="http://namespaces.plone.org/plone"
    i18n_domain="DocentIMS.dashboard">

 <!-- -*- extra stuff goes here -*- -->

  <browser:viewlet
     name="edit-button-viewlet"
     for="plone.dexterity.interfaces.IDexterityItem"
     manager="plone.app.layout.viewlets.interfaces.IBelowContent"
     layer="DocentIMS.dashboard.interfaces.IDocentimsDashboardLayer"
     class=".edit_button_viewlet.EditButtonViewlet"
     template="edit-button-viewlet.pt"
     permission="cmf.ManagePortal"
     />


</configure>
