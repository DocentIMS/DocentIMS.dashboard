<?xml version='1.0' encoding='utf8'?>
<model xmlns:i18n="http://xml.zope.org/namespaces/i18n"
  xmlns:marshal="http://namespaces.plone.org/supermodel/marshal"
  xmlns:form="http://namespaces.plone.org/supermodel/form"
  xmlns:security="http://namespaces.plone.org/supermodel/security"
  xmlns:indexer="http://namespaces.plone.org/supermodel/indexer"
  xmlns:lingua="http://namespaces.plone.org/supermodel/lingua"
  xmlns:users="http://namespaces.plone.org/supermodel/users"
  xmlns="http://namespaces.plone.org/supermodel/schema">
  <schema>

    <field name="project_title" type="zope.schema.TextLine">
      <description>Can be changed</description>
      <required>False</required>
      <title>Project Title</title>
    </field>

    <field name="project_short_name" type="zope.schema.TextLine">
      <description>Can be changed</description>
      <required>False</required>
      <title>Project Short Name</title>
    </field>

    <field name="very_short_name" type="zope.schema.TextLine">
      <description>Can be changed</description>
      <required>False</required>
      <title>Project Very Short Name</title>
    </field>

    <field name="project_url" type="zope.schema.URI">
      <description>Full path to site. e.g. https://your.site.com</description>
      <title>Project URL</title>
    </field>

    <field name="add_users" type="zope.schema.Set">
      <description>We will use this to add users to project site. Later we will use field above</description>
      <required>False</required>
       
      <title>Add Employee(s)</title>
      <value_type type="zope.schema.Choice">
        <vocabulary>plone.app.vocabularies.Users</vocabulary>
      </value_type>  
       
    </field>
 
  </schema>
</model>