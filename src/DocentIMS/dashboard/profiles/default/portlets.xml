<?xml version="1.0"?>
<portlets xmlns:i18n="http://xml.zope.org/namespaces/i18n" i18n:domain="plone">
  <!-- Extra portlets here  -->

  <portlet addview="DocentIMS.dashboard.portlets.Infoportlet" title="InfoPortlet" description="A portlet which can render weather of the given place." i18n:attributes="title title_infoportlet;
                     description description_infoportlet">

    <!-- This will enable the portlet for right column,
    left column and the footer too.
    -->
    <for interface="plone.app.portlets.interfaces.IColumn" />

    <!--
    This will enable the portlet in the dashboard.
    -->
    <!--<for interface="plone.app.portlets.interfaces.IDashboard" />-->

  </portlet>

  <assignment name="title-1" category="context" key="/" 
    manager="plone.rightcolumn" type="DocentIMS.dashboard.portlets.Infoportlet" visible="True">
    <property name="tittel">Project News</property>
  </assignment>
  <assignment name="help" category="context" key="/" manager="plone.rightcolumn" type="plone.portlet.static.Static" visible="True">
    <property name="footer"/>
    <property name="header">Docent Help</property>
    <property name="more_url"/>
    <property name="omit_border">False</property>
    <property name="text" type="plone.app.textfield.value.RichTextValue" mimeType="text/html" outputMimeType="text/x-html-safe" encoding="utf-8">
      <p style="text-align:center">
        <a href="https://docentdashboard.org/online-help-guides" title="Docent Help" target="_blank" rel="noopener">
          <img src="/++plone++DocentIMS.dashboard/help-icon.svg" alt="Docent Help" width="48" height="48"/>
          <br/>Docent Help
        </a>
      </p>
    </property>
  </assignment>


</portlets>